# ── Local secrets across git worktrees ───────────────────────────────────
# .env / .env.local are gitignored, so `git worktree add` does NOT copy them.
# One canonical copy is kept in the shared git dir (.git/ech-local-env/, chmod
# 600, never committed) and symlinked into every worktree. A post-checkout hook
# links new worktrees automatically; run `npm run setup:env` to (re)link the
# current one or seed the canonical copy the first time. Edit a secret once and
# every worktree sees it. See scripts/setup-local-env.sh.
#
# ── Paystack payment flow (Hostinger deployment) ─────────────────────────
#
# Client (build-time): set this before `pnpm build`, or in a local .env.local.
# Safe to expose — it's baked into the checkout island.
VITE_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Server (runtime, PHP): these are read by api/verify-payment.php via getenv().
# On Hostinger, set them ONE of two ways:
#   1. hPanel → Advanced → set as PHP/environment variables, OR
#   2. create a private ech-config.php one directory above public_html that
#      calls putenv(), e.g. <?php putenv('PAYSTACK_SECRET_KEY=sk_live_...');
# Never commit real secret keys.
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Fulfilment email (toSend) ────────────────────────────────────────────
# Absent → the PHP logs what it would send instead (safe to test without it).
# Endpoint: POST https://api.tosend.com/v2/emails (Authorization: Bearer tsend_...)
# Shared by api/verify-payment.php (purchase fulfilment) AND api/quiz-lead.php
# (the Grad School Match lead report + team notification). No extra vars needed
# for the match tool; leads are stored in api/_leads/ (deny-all, never web-served).
TOSEND_API_KEY=tsend_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPS_EMAIL=elevatewithnll@gmail.com
MAIL_FROM=Elevate Career Hub <noreply@elevatecareerhub.com>
PUBLIC_APP_BASE_URL=https://elevatecareerhub.com

# ── Supabase (runtime data: leads, campaign state, purchases, scholarships) ─
# ALL runtime data lives in the dedicated Elevate Supabase project so a
# Hostinger redeploy (which wipes public_html) can never lose it. PHP calls
# the PostgREST/Storage REST APIs with the SERVICE key — server-only, never
# expose it to the browser. Set both in ech-config.php above public_html on
# Hostinger, and in .env.local for `npm run serve:php`.
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=replace_with_service_role_or_sb_secret_key
# Local-dev only: where fallback spools / caches / outage CVs are written.
# Defaults to ../ech-data (one level above the web root) in production.
# ECH_DATA_DIR=./.ech-data

# ── Private admin dashboard ──────────────────────────────────────────────
# Runtime-only PHP secret for /admin/. Set this in Hostinger env or in the
# private ech-config.php file above public_html. The admin shell is
# public/noindexed, but all data endpoints require this session login.
ADMIN_PASSWORD=replace_with_a_long_random_password
ADMIN_SESSION_TTL_SECONDS=86400

# Hostinger cron calls /api/run-lead-campaign.php?secret=... to send due
# Grad School Match bootcamp follow-up emails. Use a different long random
# value from ADMIN_PASSWORD.
CRON_SECRET=replace_with_a_long_random_cron_secret

# Note: the deploy target is Hostinger (LiteSpeed + PHP). Headers/redirects
# live in deploy/htaccess.conf → dist/.htaccess. netlify.toml / vercel.json
# and netlify/functions/* are NOT used by Hostinger (kept only for portability).

# ── SEO/GEO data tools (analytics only — see seo/tools/README.md) ─────────
# Read-only credentials for the seo-nightly / seo-weekly routines. NOT a build
# dependency: the content pipeline runs fully without them, each tool just exits
# with a message. These are unrelated to the Paystack/Tosend runtime secrets above.
# Put real values in a git-ignored .env.local, never commit them.
#
# DataForSEO (paid: live SERP positions, keyword volume, related keywords).
DATAFORSEO_LOGIN=you@example.com
DATAFORSEO_PASSWORD=xxxxxxxxxxxxxxxx
# Optional location/language overrides (default 2288 = Ghana, en).
# DFS_LOCATION_CODE=2288
# DFS_LANGUAGE_CODE=en
#
# Google Search Console (free: top queries/pages). Service-account auth.
# GSC_SERVICE_ACCOUNT_JSON = path to the JSON key file, or the inline JSON itself.
# GSC_SITE_URL             = the property, e.g. https://elevatecareerhub.com/
#                            or sc-domain:elevatecareerhub.com
GSC_SERVICE_ACCOUNT_JSON=/path/to/gsc-service-account.json
GSC_SITE_URL=sc-domain:elevatecareerhub.com
#
# Bing Webmaster Tools (free: query stats; Bing's index also feeds ChatGPT/Copilot).
BING_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BING_SITE_URL=https://elevatecareerhub.com/
