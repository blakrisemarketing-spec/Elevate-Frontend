{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": false,
  "trailingSlash": true,
  "redirects": [
    { "source": "/cart/", "destination": "/contact-us/", "permanent": false },
    { "source": "/checkout/", "destination": "/contact-us/", "permanent": false },
    { "source": "/my-account/", "destination": "/contact-us/", "permanent": false },
    { "source": "/shop/", "destination": "/contact-us/", "permanent": false },
    { "source": "/manage-profile/", "destination": "/contact-us/", "permanent": false },
    { "source": "/index.php/about/", "destination": "/about/", "permanent": true },
    { "source": "/index.php/contact-us/", "destination": "/contact-us/", "permanent": true },
    { "source": "/index.php/diy-products/", "destination": "/diy-products/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), camera=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=(), midi=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self' https:; script-src 'self' 'unsafe-inline' https://js.paystack.co; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://api.paystack.co; frame-src https://checkout.paystack.com https://*.paystack.co; object-src 'none'; base-uri 'self'; frame-ancestors 'self'; form-action 'self'" }
      ]
    }
  ]
}
