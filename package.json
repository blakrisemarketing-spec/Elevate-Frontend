{
  "name": "elevate-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "npm@10.9.3",
  "engines": {
    "node": ">=20.0.0 <23.0.0"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build && node scripts/build-wordpress-html.mjs && tailwindcss -i src/priority/styles.css -o .tmp/priority.css --minify && node scripts/build-priority-routes.mjs",
    "build:priority": "tailwindcss -i src/priority/styles.css -o .tmp/priority.css --minify && node scripts/build-priority-routes.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "serve:php": "node scripts/serve-php.mjs",
    "setup:env": "sh scripts/setup-local-env.sh",
    "seed:scholarships": "node scripts/seed-scholarships.mjs",
    "seed:admin-users": "php scripts/seed-admin-users.php",
    "crawl": "node scripts/crawl-wordpress.mjs && node scripts/repair-migration.mjs",
    "repair": "node scripts/repair-migration.mjs",
    "audit": "node scripts/audit.mjs",
    "bench": "node scripts/perf-bench.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "read-excel-file": "^9.2.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.11"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.28.0",
    "playwright": "^1.49.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.19.0"
  }
}
